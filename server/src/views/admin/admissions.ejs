<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Admissions Applications | MIDWIFERY Admin</title>
    <link rel="stylesheet" href="/styles.css" />
  </head>
  <body>
    <header class="admin-header">
      <div class="container">
        <h1>Admission Applications</h1>
        <a href="/admin" class="button">Dashboard</a>
      </div>
    </header>
    <main class="container admin-content">
      <section class="panel-block">
        <div class="table-scroll">
          <table>
            <thead>
              <tr><th>Name</th><th>Email</th><th>Program</th><th>Submitted</th></tr>
            </thead>
            <tbody>
              <% applications.forEach(app => { %>
                <tr>
                  <td><%= app.fullName %></td>
                  <td><%= app.email %></td>
                  <td><%= app.program %></td>
                  <td><%= new Date(app.submittedAt).toDateString() %></td>
                </tr>
              <% }) %>
            </tbody>
          </table>
        </div>
      </section>
    </main>
  </body>
</html>
